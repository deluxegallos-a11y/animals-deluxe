  "private": true,
  "description": "Plataforma e-commerce headless de Animals Deluxe — Web pública + Panel admin + API del bot UChat (contraentrega)",
  "scripts": {
    "dev": "NODE_OPTIONS=--no-experimental-webstorage next dev",
    "build": "NODE_OPTIONS=--no-experimental-webstorage next build",
