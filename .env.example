# ─────────────────────────────────────────────────────────────
#  ANIMALS DELUXE · Variables de entorno
#  Copia este archivo a .env.local y rellena los valores.
#  SIN .env.local la plataforma corre en MODO DEMO (mock, sin login).
# ─────────────────────────────────────────────────────────────

# --- Base de datos (Supabase → Project Settings → Database) ---
# App: connection string "Transaction" (pooler, 6543). Migración/seed: "Session"/direct (5432).
DATABASE_URL=postgres://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DIRECT_DATABASE_URL=postgres://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Storage (bucket público de imágenes de producto) ---
SUPABASE_STORAGE_BUCKET=product-images

# --- Seguridad de la API ---
# Token que el bot UChat envía en x-bridge-token a /api/ai/*  (openssl rand -hex 32)
BRIDGE_TOKEN=cambia-esto-por-32-bytes-hex
# Clave AES-256 para cifrar credenciales (Wompi, UChat) — 64 chars hex (openssl rand -hex 32)
ENCRYPTION_KEY=cambia-esto-por-64-chars-hex
# Clave que el bot envía en x-api-key a GET /api/products/search (openssl rand -hex 24)
BOT_API_KEY=cambia-esto-por-una-clave-larga-aleatoria

# --- URLs públicas (web + CORS + product.url) ---
NEXT_PUBLIC_SITE_URL=https://animalsdeluxe.com
NEXT_PUBLIC_WHATSAPP=57XXXXXXXXXX

# --- Shopify Admin API (espejo de catálogo + libro de pedidos) ---
# La plataforma es la fuente de verdad; Shopify es el espejo. Crea una
# "custom app" en Shopify admin (Settings → Apps → Develop apps) con scopes
# write_products, write_orders, read_products, read_orders y copia el token.
# Si dejas esto vacío, puedes pegar las credenciales (cifradas) en /configuracion.
SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-10

# --- Wompi (opcional · sandbox · anticipo/prepago) ---
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=

# --- Rate limit distribuido (opcional · Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
